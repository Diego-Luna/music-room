# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
# - Host machine (npm run start:dev) → localhost
# - Inside docker compose (service "backend") → host = "postgres"
DATABASE_URL=postgresql://musicroom:musicroom@localhost:5432/musicroom?schema=public

# Redis
# - Host machine → localhost
# - Inside docker compose → host = "redis"
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-secret-key-change-me
JWT_EXPIRES_IN_SECONDS=900
JWT_REFRESH_SECRET=your-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN_SECONDS=604800

# OAuth - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - Facebook
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Rate Limiting (global)
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Rate Limiting (auth-only — stricter)
AUTH_THROTTLE_TTL=60000
AUTH_THROTTLE_LIMIT=10

# Application URLs (used in transactional emails)
APP_BASE_URL=http://localhost:3000
APP_FRONTEND_URL=http://localhost:8080

# SMTP (Mailpit in dev — UI on http://localhost:8025)
# - Host machine → localhost
# - Inside docker compose → host = "mailpit"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Music Room <no-reply@musicroom.local>"
SMTP_SECURE=false
